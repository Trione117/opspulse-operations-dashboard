@page
@model OpsPulse.Web.Pages.IndexModel
@{
    ViewData["Title"] = "OpsPulse Dashboard";
}

<div class="d-flex align-items-center justify-content-between mb-4">
    <div>
        <h1 class="display-6 fw-bold">Operations Health Dashboard</h1>
        <p class="text-muted mb-0">Tracks maintenance jobs, stale runs, incidents, and validation checks.</p>
    </div>
    <span class="badge bg-secondary fs-6">Sample Data</span>
</div>

<div class="row g-3 mb-4">
    <div class="col-md-2"><div class="card shadow-sm metric-card"><div class="card-body"><div class="text-muted">Sites</div><div class="metric">@Model.Dashboard.TotalSites</div></div></div></div>
    <div class="col-md-2"><div class="card shadow-sm metric-card"><div class="card-body"><div class="text-muted">Failed Jobs / 24h</div><div class="metric text-danger">@Model.Dashboard.FailedJobsLast24Hours</div></div></div></div>
    <div class="col-md-2"><div class="card shadow-sm metric-card"><div class="card-body"><div class="text-muted">Stale Jobs</div><div class="metric text-warning">@Model.Dashboard.JobsOlderThan24Hours</div></div></div></div>
    <div class="col-md-2"><div class="card shadow-sm metric-card"><div class="card-body"><div class="text-muted">Pending Checks</div><div class="metric text-primary">@Model.Dashboard.PendingValidationTasks</div></div></div></div>
    <div class="col-md-2"><div class="card shadow-sm metric-card"><div class="card-body"><div class="text-muted">Open Incidents</div><div class="metric text-danger">@Model.Dashboard.OpenIncidents</div></div></div></div>
    <div class="col-md-2"><div class="card shadow-sm metric-card"><div class="card-body"><div class="text-muted">High Severity</div><div class="metric text-danger">@Model.Dashboard.HighSeverityOpenIncidents</div></div></div></div>
</div>

<div class="row g-4 mb-4">
    <div class="col-lg-7">
        <div class="card shadow-sm h-100">
            <div class="card-header bg-dark text-white">Jobs Needing Review</div>
            <div class="card-body">
                <div class="table-responsive"><table class="table table-hover align-middle"><thead><tr><th>Site</th><th>Job</th><th>Status</th><th>Health</th><th>Note</th></tr></thead><tbody>
                @foreach (var job in Model.Dashboard.RecentProblemJobs)
                {
                    var health = Model.GetHealth(job.LastRunUtc, job.LastStatus);
                    <tr><td>@job.Site?.Name</td><td>@job.JobName</td><td>@job.LastStatus</td><td><span class="badge bg-@Model.GetBadgeCss(health)">@health</span></td><td>@job.FailureMessage</td></tr>
                }
                </tbody></table></div>
            </div>
        </div>
    </div>
    <div class="col-lg-5">
        <div class="card shadow-sm h-100">
            <div class="card-header bg-dark text-white">Open Incidents</div>
            <div class="card-body">
                @foreach (var incident in Model.Dashboard.RecentOpenIncidents)
                {
                    <div class="border-bottom pb-2 mb-2"><div class="d-flex justify-content-between"><strong>@incident.Title</strong><span class="badge bg-secondary">@incident.Severity</span></div><div class="text-muted small">@incident.Site?.Name - @incident.Status - @incident.DetectedAtUtc.ToString("yyyy-MM-dd HH:mm") UTC</div><a asp-page="/Incidents/Details" asp-route-id="@incident.Id" class="small">View details</a></div>
                }
            </div>
        </div>
    </div>
</div>
