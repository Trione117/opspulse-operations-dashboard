@page
@model OpsPulse.Web.Pages.Runbook.IndexModel
@{
    ViewData["Title"] = "Support Runbook";
}

<div class="mb-4">
    <h1 class="mb-2">Support Runbook</h1>
    <p class="text-muted">
        Use this flow to move from symptom review to evidence collection before escalating an operational issue.
    </p>
</div>

<div class="row g-3">
    @foreach (var step in Model.Steps)
    {
        <div class="col-md-6">
            <div class="card shadow-sm h-100">
                <div class="card-body">
                    <div class="d-flex align-items-center mb-2">
                        <span class="badge bg-dark me-2">@step.Number</span>
                        <h5 class="card-title mb-0">@step.Title</h5>
                    </div>
                    <p class="card-text text-muted">@step.Description</p>
                </div>
            </div>
        </div>
    }
</div>

<div class="alert alert-info mt-4">
    <strong>Note:</strong> This sample version uses local demo data. A production version would connect these checks to authenticated operational data sources.
</div>
